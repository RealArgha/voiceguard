# Copy this file to .env and fill in your values.
# python-dotenv loads it automatically when the server starts.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/voiceguard
# Set to 0 to run without a database (events won't be persisted)
DB_ENABLED=1

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Set to 0 to run without Redis (no pub/sub or event cache)
REDIS_ENABLED=1

# ── Model ────────────────────────────────────────────────────────────────────
# Override the auto-resolved weights path
# CNN_WEIGHTS=weights/voiceguard_cnn_finetuned.pt

# ── Whisper ──────────────────────────────────────────────────────────────────
# tiny | base | small | medium | large-v3
WHISPER_SIZE=medium
# Set to 0 to disable transcription entirely
# USE_WHISPER=1
